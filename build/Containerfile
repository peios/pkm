# PKM kernel build environment — the swappable "provider".
#
# Contains ONLY the pinned toolchain. No kernel source, no PKM source, no
# pekit: the source tree and build artifacts arrive via a mounted out/ volume,
# and pekit is bind-mounted from the host at runtime:
#
#   docker run -v "$PWD:/src" -v pkm-out:/src/out \
#              -v "$(command -v pekit):/usr/local/bin/pekit:ro" \
#              -e PKM_KACS_TCB_PUBKEY_HEX="$KEY" pkm-build \
#              pekit build kernel
#
# Pins come from build/toolchain.lock (passed as build args by the wrapper).
# Rebuilds only when the toolchain changes — rarely.

# Base pinned by digest; its apt state matches DEBIAN_SNAPSHOT below.
ARG BASE_IMAGE=debian@sha256:4e401d95de7083948053197a9c3913343cd06b706bf15eb6a0c3ccd26f436a0e
FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-euo", "pipefail", "-c"]

ARG DEBIAN_SNAPSHOT=20260610T000000Z
ARG DEBIAN_SUITE=trixie
ARG LLVM_VERSION=18
ARG RUST_VERSION=1.83.0
ARG BINDGEN_VERSION=0.65.1

# --- reproducible apt: pin every package to a snapshot.debian.org date ---
# Must mirror the base image's suites (main + updates + security); the
# pre-installed runtime libs come from the -updates/-security pockets, so a
# bare `trixie main` would leave dev packages unable to match them. Release
# files in the archive are old, so Check-Valid-Until must be off.
RUN rm -f /etc/apt/sources.list.d/*.sources && \
    { printf 'deb http://snapshot.debian.org/archive/debian/%s/ %s main\n' \
          "${DEBIAN_SNAPSHOT}" "${DEBIAN_SUITE}"; \
      printf 'deb http://snapshot.debian.org/archive/debian/%s/ %s-updates main\n' \
          "${DEBIAN_SNAPSHOT}" "${DEBIAN_SUITE}"; \
      printf 'deb http://snapshot.debian.org/archive/debian-security/%s/ %s-security main\n' \
          "${DEBIAN_SNAPSHOT}" "${DEBIAN_SUITE}"; \
    } > /etc/apt/sources.list && \
    printf 'Acquire::Check-Valid-Until "false";\nAcquire::Retries "5";\n' \
        > /etc/apt/apt.conf.d/99pkm

# --- toolchain + kernel C build deps ---
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        clang-${LLVM_VERSION} lld-${LLVM_VERSION} llvm-${LLVM_VERSION} \
        libclang-${LLVM_VERSION}-dev \
        build-essential bc bison flex \
        libelf-dev libssl-dev openssl \
        dwarves cpio kmod debugedit \
        python3 perl lua5.4 \
        git ca-certificates curl xz-utils zstd rsync \
        golang-go \
        qemu-system-x86 \
        ccache && \
    rm -rf /var/lib/apt/lists/*

# Rust lives in /opt (not /root) and is world-readable so the image can run as
# an arbitrary `--user` (keeps build output owned by the host user, not root).
ENV RUSTUP_HOME=/opt/rustup
ENV CARGO_HOME=/opt/cargo
# Debian ships unversioned LLVM tool names under /usr/lib/llvm-N/bin, so a plain
# `make LLVM=1` resolves clang/ld.lld/llvm-* with no symlink juggling.
ENV PATH="/usr/lib/llvm-${LLVM_VERSION}/bin:/opt/cargo/bin:${PATH}"
ENV LIBCLANG_PATH="/usr/lib/llvm-${LLVM_VERSION}/lib"

# --- Rust: kernel Kbuild toolchain (rustc + rust-src) + rustfmt (bindgen
#     formats generated UAPI bindings with it), pinned ---
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
        sh -s -- -y --default-toolchain none --profile minimal && \
    rustup toolchain install "${RUST_VERSION}" --component rust-src --component rustfmt && \
    rustup default "${RUST_VERSION}"

# --- bindgen: exact version the pinned kernel requires ---
RUN cargo install --locked --version "${BINDGEN_VERSION}" bindgen-cli && \
    chmod -R a+rX /opt/rustup /opt/cargo

# --- userspace tooling build deps (tools/*: perf, bpftool, cpupower, turbostat,
#     rtla, rv) ---
# Last, so this layer never busts the expensive Rust/bindgen cache above. These
# libs are NOT used by build.kernel, so they don't affect kernel reproducibility;
# the in-tree userspace tools just build from the same staged source. Kept in this
# one image (no second image to maintain) since the kernel build never links them.
# libcapstone-dev + llvm-${LLVM_VERSION}-dev are perf's in-process disassemblers
# (perf annotate / Intel-PT decode): without them perf auto-detects OFF and falls
# back to objdump. llvm-N-dev is the libLLVM *dev* package perf links — distinct
# from the clang/llvm runtime + libclang-dev the kernel build uses above.
# libbpf-dev + bpftool enable rtla/rv's in-kernel BPF sampling backend (osnoise/
# timerlat run with low overhead instead of the tracefs fallback) and the BPF
# skeleton generation it needs; libcpupower-dev lets rtla manage CPU idle states
# during a run. These add libbpf.so.1 (rtla, rv) and libcpupower.so.1 (rtla) as
# runtime deps — perf is unaffected (it links its own in-tree libbpf statically).
# The last line is perf's remaining optional integrations: libdebuginfod-dev
# (debuginfod auto-fetch), systemtap-sdt-dev (USDT/SDT events; header-only, no
# runtime dep), libbabeltrace-dev (`perf data` CTF export), and default-jdk
# (JVMTI agent libperf-jvmti.so; build.tools passes JDIR). debuginfod/babeltrace
# add libdebuginfod.so/libbabeltrace.so to perf's runtime deps; the JDK is huge in
# the image but only yields a tiny jvmti .so in the package. source-highlight is
# the asciidoc filter that colourises the libperf docs' [source] blocks — purely
# build-time (no package effect), it just silences asciidoc filter-127 warnings.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        pkg-config \
        libdw-dev zlib1g-dev libzstd-dev \
        libcap-dev libnuma-dev libslang2-dev \
        libtraceevent-dev libtracefs-dev \
        libpci-dev gettext \
        libperl-dev binutils-dev \
        python3-dev python3-docutils python3-setuptools \
        libpfm4-dev asciidoc xmlto \
        libudev-dev libncurses-dev \
        libnl-3-dev libnl-genl-3-dev libconfig-dev \
        autoconf automake libtool \
        libcapstone-dev llvm-${LLVM_VERSION}-dev \
        libbpf-dev bpftool libcpupower-dev \
        libdebuginfod-dev systemtap-sdt-dev libbabeltrace-dev default-jdk \
        source-highlight && \
    rm -rf /var/lib/apt/lists/*

# ccache lives in a mounted volume; make the mountpoint world-writable so a
# fresh named volume inherits 1777 and a non-root --user run can write to it.
ENV CCACHE_DIR=/ccache
ENV CCACHE_MAXSIZE=10G
RUN mkdir -p /ccache && chmod 1777 /ccache

WORKDIR /src
