From: Peios <kernel@peios.org>
Subject: FACS patch 10: security_file_getxattr for fgetxattr

Add security_file_getxattr(file, name) called in the fgetxattr()
path while struct file * is available. KACS checks:
- SD xattrs: unconditional deny (must use kacs_get_sd)
- Other xattrs: FILE_READ_EA in granted mask

--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -212,6 +212,7 @@
 LSM_HOOK(int, 0, file_truncate, struct file *file)
+LSM_HOOK(int, 0, file_getxattr, struct file *file, const char *name)
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -570,6 +570,7 @@
 int security_file_truncate(struct file *file);
+int security_file_getxattr(struct file *file, const char *name);
--- a/security/security.c
+++ b/security/security.c
@@ -3200,6 +3200,11 @@
 }

+int security_file_getxattr(struct file *file, const char *name)
+{
+	return call_int_hook(file_getxattr, file, name);
+}
+
--- a/fs/xattr.c
+++ b/fs/xattr.c
@@ -fgetxattr path @@
+	ret = security_file_getxattr(f, name);
+	if (ret)
+		return ret;
