From: Peios <kernel@peios.org>
Subject: FACS patch 10: security_file_getxattr for fgetxattr

Add security_file_getxattr(file, name) hook called in
file_getxattr() before resolving to do_getxattr. KACS checks:
SD xattrs → unconditional deny. Others → FILE_READ_EA in granted.

--- a/fs/xattr.c
+++ b/fs/xattr.c
@@ -801,5 +801,8 @@
 ssize_t file_getxattr(struct file *f, struct kernel_xattr_ctx *ctx)
 {
+	int err = security_file_getxattr(f, ctx->kname->name);
+	if (err)
+		return err;
 	audit_file(f);
 	return do_getxattr(file_mnt_idmap(f), f->f_path.dentry, ctx);
 }
