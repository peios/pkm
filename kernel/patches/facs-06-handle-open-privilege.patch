From: Peios <kernel@peios.org>
Subject: FACS patch 6: gate open_by_handle_at behind LSM hook

open_by_handle_at() bypasses directory traversal. FACS grants
CAP_DAC_READ_SEARCH universally, removing the existing gate.
Add security_file_handle_open() hook called before handle-based
opens. KACS checks SeChangeNotifyPrivilege.

--- a/fs/fhandle.c
+++ b/fs/fhandle.c
@@ -13,3 +13,4 @@
 #include <linux/personality.h>
+#include <linux/security.h>

 #include <linux/uaccess.h>
@@ -420,5 +421,9 @@
 {
 	long retval;
 	struct path path __free(path_put) = {};
+
+	retval = security_file_handle_open();
+	if (retval)
+		return retval;

 	retval = handle_to_path(mountdirfd, ufh, &path, open_flag);
