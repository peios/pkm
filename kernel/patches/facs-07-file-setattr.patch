From: Peios <kernel@peios.org>
Subject: FACS patch 7: security_file_setattr for fd-based metadata ops

Linux's security_inode_setattr receives a struct dentry *, not a
struct file * — the kernel resolves fd→dentry before the LSM hook
fires. This prevents FACS from checking the fd's granted mask for
fchmod, fchown, and futimens.

Add security_file_setattr(file, iattr) called in the fd-based
syscall paths while the struct file * is still available. KACS
checks the granted mask:
  fchmod → WRITE_DAC
  fchown → WRITE_OWNER
  futimens → FILE_WRITE_ATTRIBUTES

The subsequent security_inode_setattr becomes a no-op for fd-based
calls (coordinated via the task-local kacs_file_decision marker).

--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -212,6 +212,8 @@
 LSM_HOOK(int, 0, file_truncate, struct file *file)
+LSM_HOOK(int, 0, file_setattr, struct file *file,
+	 struct iattr *attr)
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -570,6 +570,7 @@
 int security_file_truncate(struct file *file);
+int security_file_setattr(struct file *file, struct iattr *attr);
--- a/security/security.c
+++ b/security/security.c
@@ -3200,6 +3200,11 @@
 }

+int security_file_setattr(struct file *file, struct iattr *attr)
+{
+	return call_int_hook(file_setattr, file, attr);
+}
+
--- a/fs/open.c
+++ b/fs/open.c
@@ -766,6 +766,12 @@
 int vfs_fchmod(struct file *file, umode_t mode)
 {
+	struct iattr attr = { .ia_valid = ATTR_MODE, .ia_mode = mode };
+	int err;
+	err = security_file_setattr(file, &attr);
+	if (err)
+		return err;
 	audit_file(file);
--- a/fs/open.c
+++ b/fs/open.c
@@ -chown_common,+6 @@
+/* In the fd-based chown path (fchown/fchown32), call the file hook. */
+	if (file) {
+		struct iattr attr = { .ia_valid = ATTR_UID | ATTR_GID };
+		int err = security_file_setattr(file, &attr);
+		if (err)
+			return err;
+	}
--- a/fs/utimes.c
+++ b/fs/utimes.c
@@ -futimens path @@
+	if (file) {
+		struct iattr attr = { .ia_valid = ATTR_ATIME | ATTR_MTIME };
+		int err = security_file_setattr(file, &attr);
+		if (err)
+			goto out;
+	}
