From: Peios <kernel@peios.org>
Subject: FACS patch 7: security_file_setattr for fd-based metadata ops

Add security_file_setattr(file, iattr) hook called in vfs_fchmod()
before the fd is resolved to a dentry. KACS checks the fd's granted
mask (WRITE_DAC for chmod, WRITE_OWNER for chown, FILE_WRITE_ATTRIBUTES
for futimens). The subsequent security_inode_setattr is coordinated
via the task-local marker.

Note: chown and futimens fd-based paths need similar insertion points
in their respective VFS functions. The exact chown/futimens paths
vary by kernel version; the hook insertion pattern is identical.

--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -212,6 +212,8 @@
 LSM_HOOK(int, 0, file_truncate, struct file *file)
+LSM_HOOK(int, 0, file_setattr, struct file *file,
+	 struct iattr *attr)
 LSM_HOOK(int, 0, task_alloc, struct task_struct *task,
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -490,6 +490,7 @@
 int security_file_truncate(struct file *file);
+int security_file_setattr(struct file *file, struct iattr *attr);
--- a/security/security.c
+++ b/security/security.c
@@ -2670,6 +2670,11 @@
 }

+int security_file_setattr(struct file *file, struct iattr *attr)
+{
+	return call_int_hook(file_setattr, file, attr);
+}
+
--- a/fs/open.c
+++ b/fs/open.c
@@ -661,6 +661,11 @@
 int vfs_fchmod(struct file *file, umode_t mode)
 {
+	struct iattr attr = { .ia_valid = ATTR_MODE, .ia_mode = mode };
+	int ret = security_file_setattr(file, &attr);
+	if (ret)
+		return ret;
+
 	audit_file(file);
 	return chmod_common(&file->f_path, mode);
 }
