From: Peios <kernel@peios.org>
Subject: FACS patch 7c: security_file_setattr for futimens

--- a/fs/utimes.c
+++ b/fs/utimes.c
@@ -110,6 +110,15 @@
 	CLASS(fd, f)(fd);
 	if (fd_empty(f))
 		return -EBADF;
+#ifdef CONFIG_SECURITY_PKM
+	{
+		extern int security_file_setattr(struct file *, struct iattr *);
+		struct iattr fsa = { .ia_valid = ATTR_ATIME | ATTR_MTIME };
+		int ret = security_file_setattr(fd_file(f), &fsa);
+		if (ret)
+			return ret;
+	}
+#endif
 	return vfs_utimes(&fd_file(f)->f_path, times);
 }
