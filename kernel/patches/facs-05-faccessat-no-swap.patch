From: Peios <kernel@peios.org>
Subject: FACS patch 5: skip credential swap in do_faccessat

On Peios, setuid does not exist. The credential swap in access()
evaluates the primary token instead of the effective token. Add
security_access_use_effective() hook — returns nonzero to skip
the swap. KACS always returns true.

--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -212,6 +212,7 @@
 LSM_HOOK(int, 0, file_truncate, struct file *file)
+LSM_HOOK(int, 0, access_use_effective, void)
 LSM_HOOK(int, 0, task_alloc, struct task_struct *task,
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -490,6 +490,7 @@
 int security_file_truncate(struct file *file);
+int security_access_use_effective(void);
--- a/security/security.c
+++ b/security/security.c
@@ -2670,6 +2670,11 @@
 }

+int security_access_use_effective(void)
+{
+	return call_int_hook(access_use_effective);
+}
+
--- a/fs/open.c
+++ b/fs/open.c
@@ -391,6 +391,9 @@
 	const struct cred *cred;

+	if (security_access_use_effective())
+		return false;
+
 	if (flags & AT_EACCESS)
 		return false;
