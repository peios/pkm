From: Peios <kernel@peios.org>
Subject: FACS patch 11: security_file_setxattr for fsetxattr/fremovexattr

Add security_file_setxattr(file, name) hook called in
file_setxattr() and file_removexattr() before the dentry-based
path. KACS checks: SD xattrs → deny. POSIX ACLs → deny.
Others → FILE_WRITE_EA in granted.

--- a/fs/xattr.c
+++ b/fs/xattr.c
@@ -640,5 +640,8 @@
 int file_setxattr(struct file *f, struct kernel_xattr_ctx *ctx)
 {
+	int serr = security_file_setxattr(f, ctx->kname->name);
+	if (serr)
+		return serr;
 	int error = mnt_want_write_file(f);

 	if (!error) {
@@ -1026,5 +1029,8 @@
 static int file_removexattr(struct file *f, struct xattr_name *kname)
 {
+	int serr = security_file_setxattr(f, kname->name);
+	if (serr)
+		return serr;
 	int error = mnt_want_write_file(f);

 	if (!error) {
