From: Peios <kernel@peios.org>
Subject: FACS patches 1-4,8: append-only enforcement via security_file_deny_pwrite

The security_file_permission LSM hook cannot distinguish positioned
writes (pwrite) from sequential writes — both arrive as MAY_WRITE.
Add security_file_deny_pwrite(file) hook. Returns nonzero if
positioned/mutation writes should be denied (fd is append-only).

Called from five sites:
  1. ksys_pwrite64() — positioned single-buffer write
  2. do_pwritev() — positioned vectored write + RWF_NOAPPEND
  3. io_write() in io_uring — positioned write via io_uring
  4. aio_write() in fs/aio.c — positioned write via legacy AIO
  8. vfs_fallocate() — PUNCH_HOLE/ZERO_RANGE/COLLAPSE/INSERT modes

--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -212,6 +212,7 @@
 LSM_HOOK(int, 0, file_truncate, struct file *file)
+LSM_HOOK(int, 0, file_deny_pwrite, struct file *file)
 LSM_HOOK(int, 0, task_alloc, struct task_struct *task,
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -490,6 +490,7 @@
 int security_file_truncate(struct file *file);
+int security_file_deny_pwrite(struct file *file);
 int security_task_alloc(struct task_struct *task, u64 clone_flags);
--- a/security/security.c
+++ b/security/security.c
@@ -2670,6 +2670,11 @@
 }

+int security_file_deny_pwrite(struct file *file)
+{
+	return call_int_hook(file_deny_pwrite, file);
+}
