From: Peios <kernel@peios.org>
Subject: FACS patches 1-4,8: append-only enforcement via security_file_deny_pwrite

The security_file_permission LSM hook cannot distinguish positioned
writes (pwrite) from sequential writes — both arrive as MAY_WRITE.
Add security_file_deny_pwrite(file) hook. Returns nonzero if
positioned/mutation writes should be denied (fd is append-only).

Called from five sites:
  1. ksys_pwrite64() — positioned single-buffer write
  2. do_pwritev() — positioned vectored write + RWF_NOAPPEND
  3. io_write() in io_uring — positioned write via io_uring
  4. aio_write() in fs/aio.c — positioned write via legacy AIO
  8. vfs_fallocate() — PUNCH_HOLE/ZERO_RANGE/COLLAPSE/INSERT modes

--- a/fs/read_write.c
+++ b/fs/read_write.c
@@ -790,5 +790,8 @@
 	if (fd_empty(f))
 		return -EBADF;

+	if (security_file_deny_pwrite(fd_file(f)))
+		return -EPERM;
+
 	if (fd_file(f)->f_mode & FMODE_PWRITE)
 		return vfs_write(fd_file(f), buf, count, &pos);
@@ -1150,4 +1153,10 @@
 	if (!fd_empty(f)) {
 		ret = -ESPIPE;
+		if (security_file_deny_pwrite(fd_file(f))) {
+			ret = -EPERM;
+		} else if ((flags & RWF_NOAPPEND) &&
+			   security_file_deny_pwrite(fd_file(f))) {
+			ret = -EPERM;
+		} else
 		if (fd_file(f)->f_mode & FMODE_PWRITE)
 			ret = vfs_writev(fd_file(f), vec, vlen, &pos, flags);
--- a/io_uring/rw.c
+++ b/io_uring/rw.c
@@ -16,3 +16,4 @@
 #include <linux/nospec.h>
+#include <linux/security.h>

 #include <uapi/linux/io_uring.h>
@@ -1143,3 +1144,7 @@
 	if (unlikely(ret))
 		return ret;
+
+	if (security_file_deny_pwrite(req->file))
+		return -EPERM;
+
 	req->cqe.res = iov_iter_count(&io->iter);
--- a/fs/aio.c
+++ b/fs/aio.c
@@ -1629,4 +1629,8 @@
 	ret = rw_verify_area(WRITE, file, &req->ki_pos, iov_iter_count(&iter));
 	if (!ret) {
+		if (security_file_deny_pwrite(file))
+			ret = -EPERM;
+	}
+	if (!ret) {
 		if (S_ISREG(file_inode(file)->i_mode))
 			kiocb_start_write(req);
--- a/fs/open.c
+++ b/fs/open.c
@@ -290,5 +290,12 @@
 	if (!(file->f_mode & FMODE_WRITE))
 		return -EBADF;

+	/* FACS patch 8: deny mutation fallocate modes on append-only fds. */
+	if (mode & (FALLOC_FL_PUNCH_HOLE | FALLOC_FL_ZERO_RANGE |
+		    FALLOC_FL_COLLAPSE_RANGE | FALLOC_FL_INSERT_RANGE)) {
+		if (security_file_deny_pwrite(file))
+			return -EPERM;
+	}
+
