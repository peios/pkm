From: Peios <kernel@peios.org>
Subject: prlimit: add security_task_prlimit_target hook with task_struct

The existing security_task_prlimit hook receives only credential
pairs, preventing LSMs from looking up per-task security state
(e.g., process SDs, PIP trust levels). Add a new hook that receives
the target task_struct, called from the prlimit64 syscall where the
task is available. The existing hook is unchanged for LSM stacking
compatibility.

--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -250,4 +250,5 @@
 LSM_HOOK(int, 0, task_prlimit, const struct cred *cred,
 	 const struct cred *tcred, unsigned int flags)
+LSM_HOOK(int, 0, task_prlimit_target, struct task_struct *target, unsigned int flags)
 LSM_HOOK(int, 0, task_setrlimit, struct task_struct *p, unsigned int resource,
 	 struct rlimit *new_rlim)
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -523,4 +523,5 @@
 int security_task_prlimit(const struct cred *cred, const struct cred *tcred,
 			  unsigned int flags);
+int security_task_prlimit_target(struct task_struct *target, unsigned int flags);
 int security_task_setrlimit(struct task_struct *p, unsigned int resource,
 			    struct rlimit *new_rlim);
--- a/security/security.c
+++ b/security/security.c
@@ -3119,4 +3119,17 @@
 }

 /**
+ * security_task_prlimit_target() - Check prlimit with target task
+ * @target: target task
+ * @flags: LSM_PRLIMIT_* flags
+ *
+ * Like security_task_prlimit() but provides the target task_struct
+ * so LSMs can access per-task security state (process SDs, PIP).
+ */
+int security_task_prlimit_target(struct task_struct *target, unsigned int flags)
+{
+	return call_int_hook(task_prlimit_target, target, flags);
+}
+
+/**
  * security_task_setrlimit() - Check if setting a new rlimit value is allowed
--- a/kernel/sys.c
+++ b/kernel/sys.c
@@ -1759,5 +1759,10 @@
 		rcu_read_unlock();
 		return ret;
 	}
+	ret = security_task_prlimit_target(tsk, checkflags);
+	if (ret) {
+		rcu_read_unlock();
+		return ret;
+	}
 	get_task_struct(tsk);
 	rcu_read_unlock();
