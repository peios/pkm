From: Peios <kernel@peios.org>
Subject: FACS: register all custom LSM hooks

Combined hook definitions for all FACS custom LSM hooks. Applied as
a single patch because they all insert at the same location.

diff --git a/include/linux/lsm_hook_defs.h b/include/linux/lsm_hook_defs.h
--- a/include/linux/lsm_hook_defs.h
+++ b/include/linux/lsm_hook_defs.h
@@ -212,2 +212,10 @@
 LSM_HOOK(int, 0, file_truncate, struct file *file)
+LSM_HOOK(int, 0, file_deny_pwrite, struct file *file)
+LSM_HOOK(int, 0, access_use_effective, void)
+LSM_HOOK(int, 0, file_handle_open, void)
+LSM_HOOK(int, 0, file_setattr, struct file *file,
+	 struct iattr *attr)
+LSM_HOOK(int, 0, file_getattr, struct file *file)
+LSM_HOOK(int, 0, file_getxattr, struct file *file, const char *name)
+LSM_HOOK(int, 0, file_setxattr, struct file *file, const char *name)
 LSM_HOOK(int, 0, task_alloc, struct task_struct *task,
diff --git a/include/linux/security.h b/include/linux/security.h
--- a/include/linux/security.h
+++ b/include/linux/security.h
@@ -490,2 +490,9 @@
 int security_file_truncate(struct file *file);
+int security_file_deny_pwrite(struct file *file);
+int security_access_use_effective(void);
+int security_file_handle_open(void);
+int security_file_setattr(struct file *file, struct iattr *attr);
+int security_file_getattr(struct file *file);
+int security_file_getxattr(struct file *file, const char *name);
+int security_file_setxattr(struct file *file, const char *name);
 int security_task_alloc(struct task_struct *task, u64 clone_flags);
diff --git a/security/security.c b/security/security.c
--- a/security/security.c
+++ b/security/security.c
@@ -2670,3 +2670,38 @@
 }

+int security_file_deny_pwrite(struct file *file)
+{
+	return call_int_hook(file_deny_pwrite, file);
+}
+
+int security_access_use_effective(void)
+{
+	return call_int_hook(access_use_effective);
+}
+
+int security_file_handle_open(void)
+{
+	return call_int_hook(file_handle_open);
+}
+
+int security_file_setattr(struct file *file, struct iattr *attr)
+{
+	return call_int_hook(file_setattr, file, attr);
+}
+
+int security_file_getattr(struct file *file)
+{
+	return call_int_hook(file_getattr, file);
+}
+
+int security_file_getxattr(struct file *file, const char *name)
+{
+	return call_int_hook(file_getxattr, file, name);
+}
+
+int security_file_setxattr(struct file *file, const char *name)
+{
+	return call_int_hook(file_setxattr, file, name);
+}
+
 /**
