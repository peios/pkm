From: Peios <kernel@peios.org>
Subject: FACS patch 9: security_file_getattr for fstat/statx

Add security_file_getattr(file) hook called in vfs_fstat() before
resolving to vfs_getattr. KACS checks FILE_READ_ATTRIBUTES in the
granted mask. O_PATH fds are unconditionally allowed.

--- a/fs/stat.c
+++ b/fs/stat.c
@@ -276,7 +276,11 @@
 int vfs_fstat(int fd, struct kstat *stat)
 {
+	int ret;
 	CLASS(fd_raw, f)(fd);
 	if (fd_empty(f))
 		return -EBADF;
+	ret = security_file_getattr(fd_file(f));
+	if (ret)
+		return ret;
 	return vfs_getattr(&fd_file(f)->f_path, stat, STATX_BASIC_STATS, 0);
 }
